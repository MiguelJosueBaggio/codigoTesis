            },
            {
              "name": "intentos",
              "type": "number",
              "value": "={{$json.intento}}",
              "id": "3f02649b-c464-4b8b-9dda-b4e97c9b0289"
            },
            {
              "name": "exitCode",
              "type": "number",
              "value": "={{$json.exitCode}}",
              "id": "a5b51f47-eecb-4318-aa02-3effd0538752"
            },
            {
              "name": "stderr",
              "type": "string",
              "value": "={{$json.stderr}}",
              "id": "e1d0fd6a-783d-4398-a7b4-28ff0c93b748"
            }
          ]
        }
      }
    }
  ],
