    {
      "id": "verificar-analysis-config",
      "name": "Verificar analysis_config.yaml",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2200, -300],
      "notes": "D-8: chequeo de existencia de archivo en el filesystem del host self-hosted -- no invoca ningun modulo pipeline.*, solo resuelve una condicion para el IF siguiente.",
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const fs = require('fs');\nconst rutaConfig = $env.PIPELINE_ANALYSIS_CONFIG;\nreturn { json: { ...$json, analysis_config_existe: fs.existsSync(rutaConfig) } };"
      }
    },
    {
      "id": "if-existe-analysis-config",
      "name": "IF: Existe analysis_config.yaml",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [2420, -300],
      "parameters": {
        "conditions": {
          "combinator": "and",
          "conditions": [
            {
              "leftValue": "={{$json.analysis_config_existe}}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ]
        }
      }
    },
