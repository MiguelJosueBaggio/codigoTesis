    {
      "id": "mover-archivo-a-procesados",
      "name": "Mover Archivo a Procesados",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [1980, 200],
      "notes": "D-7: estado 'procesado' por filesystem (exito O rechazo de datos con reporte, RN-ING-04/RN-VAL-08) -- el barrido horario ya no vuelve a tomar este archivo. Utilitario de shell (mover un archivo), no invoca logica de pipeline.*.",
      "parameters": {
        "command": "={{$env.PYTHON_BIN}} -c \"import shutil, pathlib; destino = pathlib.Path(r'{{$env.PIPELINE_CARPETA_ENTRADA}}') / 'procesados'; destino.mkdir(parents=True, exist_ok=True); shutil.move(r'{{$json.ruta_archivo}}', str(destino))\""
      }
    },
    {
      "id": "mover-archivo-a-errores",
      "name": "Mover Archivo a Errores",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [1980, 450],
      "notes": "D-7: fallo persistente (escalamiento) -- el archivo se retira de la carpeta monitoreada para que el barrido horario no lo vuelva a intentar indefinidamente; queda disponible para inspeccion manual.",
      "parameters": {
        "command": "={{$env.PYTHON_BIN}} -c \"import shutil, pathlib; destino = pathlib.Path(r'{{$env.PIPELINE_CARPETA_ENTRADA}}') / 'errores'; destino.mkdir(parents=True, exist_ok=True); shutil.move(r'{{$json.ruta_archivo}}', str(destino))\""
      }
    },
    {
      "id": "detener-y-escalar",
      "name": "Detener y Escalar",
      "type": "n8n-nodes-base.stopAndError",
      "typeVersion": 1,
      "position": [2200, 600],
      "notes": "D-6: marca la ejecucion como FALLIDA en el dashboard de n8n (visible/auditable) y dispara el error workflow configurado en Settings ('escalamiento_notificacion.json') -- RN-GLB-03, notificacion humana ante fallo persistente.",
      "parameters": {
        "errorMessage": "=Fallo persistente en la etapa '{{$json.etapa}}' (run {{$json.run_id}}) tras {{$json.intentos}} intento(s). exitCode={{$json.exitCode}}. comando='{{$json.comando}}'. stderr={{$json.stderr}}"
      }
    }
