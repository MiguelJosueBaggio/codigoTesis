# Plantilla de variables de entorno — change foundation-setup (C-01)
#
# SUPUESTO DE BAJA CONFIANZA — ver knowledge-base/08_arquitectura_propuesta.md
# (§Variables de entorno) y knowledge-base/10_preguntas_abiertas.md.
# La tesis no enumera explicitamente estas variables; se infieren del
# stack descrito (DD-03, DD-09, DD-11). Ningun valor de este archivo es
# un secreto real: son ejemplos para copiar a un `.env` local.

# Cadena de conexion a la base de datos (DD-03: SQLite en desarrollo,
# PostgreSQL en produccion).
DATABASE_URL=sqlite:///./ensayos.db

# Credenciales del bot de Telegram (DD-09: unico canal de interaccion
# humana; el nodo nativo de n8n las consume).
# TELEGRAM_BOT_TOKEN=

# Credenciales del proveedor de IA opcional (C-09, apoyo de IA opcional
# sobre la interpretacion de resultados).
# AI_PROVIDER_API_KEY=

# Directorio de respaldo automatico fuera del repositorio principal
# (RN-AUD-03, change persistence-audit-module / C-06). El script
# scripts/backup.py copia dataset + bitacora + referencia de codigo a esta
# ruta. Se configura por variable de entorno (no hardcodeada en codigo)
# porque el destino depende del entorno de despliegue -- si la maquina
# cambia de disco, se redirige editando esta variable, sin tocar codigo.
# Debe resolver a una ruta FUERA del arbol del repositorio.
BACKUP_DIR=../ensayos-backups


# Orquestacion n8n (change n8n-orchestration-workflows / C-08). Todo por
# variable de entorno -- ningun JSON exportado en n8n_workflows/ contiene
# rutas absolutas de esta maquina ni credenciales (D-10, design.md).

# Interprete Python del venv del proyecto (D-10): los nodos Execute Command
# invocan SIEMPRE $PYTHON_BIN -m pipeline.<etapa> -- nunca importan Python
# directamente (DD-05). En esta maquina de desarrollo apunta a
# .venv/Scripts/python.exe (Windows) o .venv/bin/python (Unix).
PYTHON_BIN=python

# Raiz del repo -- cwd de los nodos Execute Command (D-10).
PIPELINE_ROOT=.

# Carpeta monitoreada por el Local File Trigger y el Schedule Trigger de
# barrido horario (D-7). Al terminar cada corrida, el archivo de entrada se
# mueve a PIPELINE_CARPETA_ENTRADA/procesados/ (exito o rechazo de datos con
# reporte) o PIPELINE_CARPETA_ENTRADA/errores/ (fallo persistente).
PIPELINE_CARPETA_ENTRADA=./datos_entrada

# Directorio donde cada ejecucion crea su propio corridas/<run_id>/ (D-3):
# manifest.json acumulativo + artefactos pickle de handoff entre etapas
# (ingerido.pkl, validos.pkl, rechazados.pkl, tidy.pkl) + salidas legibles
# (rechazados.csv, reporte_validacion.json, operaciones.json,
# resultado_persistencia.json).
PIPELINE_CARPETA_CORRIDAS=./corridas

# Politica de reintentos con backoff exponencial real del sub-workflow
# generico ejecutar_etapa_con_reintentos (D-5, RN-GLB-03): espera
# PIPELINE_BACKOFF_BASE_SEGUNDOS * 2^intento entre reintentos, hasta
# PIPELINE_REINTENTOS_MAX intentos antes de escalar (D-6). Defaults
# acordados en el design (checkpoint OQ-2 resuelto): 3 intentos, base 5s
# (esperas 5s, 10s, 20s).
PIPELINE_REINTENTOS_MAX=3
PIPELINE_BACKOFF_BASE_SEGUNDOS=5

# YAML de config re-ejecutable del analisis (RN-EST-04, C-07) que el nodo IF
# del workflow principal verifica antes de correr la etapa de analisis
# condicional (D-8). Si no existe, la corrida termina exitosamente en
# persistencia.
PIPELINE_ANALYSIS_CONFIG=./config/analysis_config.yaml
